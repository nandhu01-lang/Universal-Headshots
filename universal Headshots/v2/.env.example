PORT=3001
# Firebase
FIREBASE_SERVICE_ACCOUNT=./service-account.json
GCS_BUCKET_NAME=global-pro-ai.appspot.com

# Vertex AI
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=us-central1

# Payments
REVENUECAT_API_KEY=your-revenuecat-key
REVENUECAT_PRO_PACKAGE_ID=pro_pack_1799
REVENUECAT_STARTER_PACKAGE_ID=starter_pack_799

# Support & Email
SUPPORT_EMAIL_RECIPIENT=andkunch@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Client Environment (for reference, move to frontend/.env)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=global-pro-ai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=global-pro-ai
VITE_REVENUECAT_PUBLIC_KEY=your-public-key
