{
  "expo": {
    "name": "Universal Headshots",
    "slug": "universal-headshots",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "universalheadshots",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.universalheadshots.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Universal Headshots to access your camera to take photos for AI headshot generation.",
        "NSPhotoLibraryUsageDescription": "Allow Universal Headshots to access your photos to generate AI headshots."
      }
    },
    "android": {
      "package": "com.universalheadshots.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Universal Headshots to access your photos to generate professional AI portraits.",
          "cameraPermission": "Allow Universal Headshots to access your camera to take photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#8b5cf6",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
